---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';

const siteEntry = await getEntry('site', 'settings');
const hoursEntry = await getEntry('openingHours', 'hours');

if (!siteEntry || !hoursEntry) {
  throw new Error('Site settings or opening hours entry is missing.');
}

const site = siteEntry.data;
const hours = hoursEntry.data;
---

<BaseLayout
  title="Kontakt | Hopla Physio"
  description="Kontakt, Adresse und Öffnungszeiten der Praxis in der Region Zürich. (Platzhalter)"
  canonicalPath="/kontakt"
>
  <Section>
    <Container>
      <h1 class="font-display text-4xl text-slate-950 sm:text-5xl">Kontakt</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-700">
        Für Terminwünsche oder Rückfragen kannst du uns telefonisch erreichen oder das Formular nutzen. (Platzhalter)
      </p>
    </Container>
  </Section>

  <Section tone="muted">
    <Container>
      <div class="grid gap-8 lg:grid-cols-12">
        <div class="space-y-6 lg:col-span-5">
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="font-semibold text-slate-950">Praxis</h2>
            <p class="mt-3 text-sm text-slate-700">{site.practiceName}</p>
            {site.addressLines.map((line) => (
              <p class="text-sm text-slate-700">{line}</p>
            ))}
            <p class="text-sm text-slate-700">{site.postalCodeCity}</p>
            <p class="mt-4 text-sm text-slate-700">
              Tel: <a class="underline decoration-slate-300 underline-offset-2" href={`tel:${site.phone.replace(/\s+/g, '')}`}>{site.phone}</a>
            </p>
            <p class="text-sm text-slate-700">
              E-Mail: <a class="underline decoration-slate-300 underline-offset-2" href={`mailto:${site.email}`}>{site.email}</a>
            </p>
          </article>

          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="font-semibold text-slate-950">Öffnungszeiten</h2>
            <dl class="mt-3 space-y-2 text-sm">
              {hours.rows.map((row) => (
                <div class="flex items-center justify-between gap-5 border-b border-slate-100 pb-2">
                  <dt class="text-slate-700">{row.label}</dt>
                  <dd class="font-medium text-slate-900">{row.hours}</dd>
                </div>
              ))}
            </dl>
            {site.openingHoursNote ? <p class="mt-3 text-sm text-slate-700">{site.openingHoursNote}</p> : null}
          </article>
        </div>

        <div class="space-y-6 lg:col-span-7">
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="font-semibold text-slate-950">Termin anfragen</h2>
            <form
              name="kontakt"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              action="/kontakt?success=1"
              class="mt-4 space-y-4"
            >
              <input type="hidden" name="form-name" value="kontakt" />
              <p class="hidden">
                <label>
                  Nicht ausfüllen: <input name="bot-field" />
                </label>
              </p>
              <div>
                <label for="name" class="mb-1 block text-sm font-medium text-slate-800">Name</label>
                <input id="name" name="name" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none ring-sage-700 transition focus:ring-2" />
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="email" class="mb-1 block text-sm font-medium text-slate-800">E-Mail</label>
                  <input id="email" name="email" type="email" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none ring-sage-700 transition focus:ring-2" />
                </div>
                <div>
                  <label for="phone" class="mb-1 block text-sm font-medium text-slate-800">Telefon</label>
                  <input id="phone" name="phone" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none ring-sage-700 transition focus:ring-2" />
                </div>
              </div>
              <div>
                <label for="message" class="mb-1 block text-sm font-medium text-slate-800">Anliegen</label>
                <textarea id="message" name="message" rows="5" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none ring-sage-700 transition focus:ring-2"></textarea>
              </div>
              <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-sage-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sage-900">
                Nachricht senden
              </button>
            </form>
          </article>

          <article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
            <div class="aspect-[16/9] overflow-hidden rounded-xl bg-slate-100">
              {site.googleMapsEmbedUrl && site.googleMapsEmbedUrl.includes('google.com/maps/embed') ? (
                <iframe
                  title="Standortkarte der Praxis (Platzhalter)"
                  src={site.googleMapsEmbedUrl}
                  width="100%"
                  height="100%"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              ) : (
                <div class="flex h-full items-center justify-center text-sm text-slate-500">
                  Google Maps Embed Platzhalter
                </div>
              )}
            </div>
          </article>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

