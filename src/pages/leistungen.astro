---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Leistungen | Hopla Physio"
  description="Überblick unserer physiotherapeutischen Leistungen in der Region Zürich. (Platzhalter)"
  canonicalPath="/leistungen"
>
  <Section>
    <Container>
      <h1 class="font-display text-4xl text-slate-950 sm:text-5xl">Leistungen</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-700">
        Unsere Behandlungen sind individuell geplant, klar kommuniziert und auf deinen Alltag abgestimmt. (Platzhalter)
      </p>
    </Container>
  </Section>

  <Section tone="muted">
    <Container>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="font-semibold text-slate-950">{service.data.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-700">{service.data.summary}</p>
          </article>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

