---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Team | Hopla Physio"
  description="Lerne unser Team von Physiotherapeutinnen und Physiotherapeuten kennen. (Platzhalter)"
  canonicalPath="/team"
>
  <Section>
    <Container>
      <h1 class="font-display text-4xl text-slate-950 sm:text-5xl">Team</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-700">
        Fachlich stark, menschlich klar. Wir arbeiten ruhig, präzise und mit einem gemeinsamen Ziel: deine funktionelle Verbesserung. (Platzhalter)
      </p>
    </Container>
  </Section>

  <Section tone="muted">
    <Container>
      <div class="grid gap-6 md:grid-cols-2">
        {team.map((member) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="aspect-[4/3] rounded-xl bg-slate-100">
              <div class="flex h-full items-center justify-center text-sm text-slate-500">
                Foto: {member.data.image?.alt ?? `Porträt von ${member.data.name}`} (Platzhalter)
              </div>
            </div>
            <h2 class="mt-5 text-xl font-semibold text-slate-950">{member.data.name}</h2>
            <p class="text-sm text-sage-800">{member.data.role}</p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {member.data.specialties.map((specialty) => (
                <li class="rounded-full bg-sand-100 px-3 py-1 text-xs text-slate-800">{specialty}</li>
              ))}
            </ul>
            <ul class="mt-4 space-y-1 text-sm text-slate-700">
              {member.data.credentials.map((item) => (
                <li>• {item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

