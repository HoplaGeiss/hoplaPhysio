---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Team | Praxis Lindenhof Physio"
  description="Lerne das Team der Praxis Lindenhof Physio in Zürich kennen."
  canonicalPath="/team"
>
  <Section>
    <Container>
      <h1 class="font-display text-4xl text-slate-950 sm:text-5xl">Team</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-700">
        Fachlich stark, menschlich klar. Wir arbeiten ruhig, präzise und mit einem gemeinsamen Ziel: deine funktionelle Verbesserung.
      </p>
    </Container>
  </Section>

  <Section tone="muted">
    <Container>
      <div class="grid gap-6 md:grid-cols-2">
        {team.map((member) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <img
              src={member.data.image?.src ?? '/images/team/default-team.svg'}
              alt={member.data.image?.alt ?? `Porträt von ${member.data.name}`}
              loading="lazy"
              class="aspect-[4/3] w-full rounded-xl border border-slate-200 object-cover"
            />
            <h2 class="mt-5 text-xl font-semibold text-slate-950">{member.data.name}</h2>
            <p class="text-sm text-emerald-800">{member.data.role}</p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {member.data.specialties.map((specialty) => (
                <li class="rounded-full bg-stone-100 px-3 py-1 text-xs text-slate-800">{specialty}</li>
              ))}
            </ul>
            <ul class="mt-4 space-y-1 text-sm text-slate-700">
              {member.data.credentials.map((item) => (
                <li>• {item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

