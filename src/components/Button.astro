---
type Props = {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
};

const { href, variant = 'primary', class: className } = Astro.props;

const base =
  'inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-700 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50';
const variants: Record<typeof variant, string> = {
  primary: 'bg-emerald-800 text-white hover:bg-emerald-900 shadow-sm',
  secondary: 'bg-white text-slate-900 border border-slate-200 hover:bg-stone-50',
};
---

<a href={href} class:list={[base, variants[variant], className]}>
  <slot />
</a>

