---
import Container from './Container.astro';
import { getEntry } from 'astro:content';

const nav = [
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/team', label: 'Team' },
  { href: '/kontakt', label: 'Kontakt' },
];
const siteEntry = await getEntry('site', 'settings');
const practiceName = siteEntry?.data.practiceName ?? 'Praxis Lindenhof Physio';
const locationShort = siteEntry?.data.locationShort ?? 'Zürich';
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-stone-50/80 backdrop-blur">
  <Container class="flex h-16 items-center justify-between">
    <a href="/" class="flex items-baseline gap-2 font-semibold tracking-tight text-slate-950">
      <span class="font-display text-lg">{practiceName}</span>
      <span class="text-sm text-slate-600">{locationShort}</span>
    </a>
    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-700 sm:flex">
      {nav.map((item) => (
        <a class="hover:text-slate-950" href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2 sm:hidden">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-white/60 text-slate-900 shadow-sm backdrop-blur transition hover:bg-white"
        aria-label="Menü öffnen"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-mobile-menu-button
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
          <path
            fill="currentColor"
            d="M4 6.75A.75.75 0 0 1 4.75 6h14.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 6.75Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 12Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 17.25Z"
          />
        </svg>
      </button>
    </div>
  </Container>

  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 hidden sm:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation"
    data-mobile-menu
  >
    <div class="absolute inset-0 bg-slate-950/30 backdrop-blur-[2px]" data-mobile-menu-backdrop></div>
    <div class="absolute right-0 top-0 h-full w-[min(22rem,92vw)] bg-white shadow-2xl">
      <div class="flex h-16 items-center justify-between border-b border-slate-200 px-5">
        <span class="font-display text-base font-semibold text-slate-950">Menü</span>
        <button
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-900 shadow-sm transition hover:bg-slate-50"
          aria-label="Menü schließen"
          data-mobile-menu-close
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
            <path
              fill="currentColor"
              d="M6.22 6.22a.75.75 0 0 1 1.06 0L12 10.94l4.72-4.72a.75.75 0 1 1 1.06 1.06L13.06 12l4.72 4.72a.75.75 0 1 1-1.06 1.06L12 13.06l-4.72 4.72a.75.75 0 1 1-1.06-1.06L10.94 12 6.22 7.28a.75.75 0 0 1 0-1.06Z"
            />
          </svg>
        </button>
      </div>
      <nav class="px-5 py-4 text-base font-medium text-slate-800">
        <ul class="space-y-1">
          {nav.map((item) => (
            <li>
              <a
                class="block rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-slate-950"
                href={item.href}
                data-mobile-menu-link
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-4 border-t border-slate-200 pt-4">
          <a
            href="/kontakt"
            class="block rounded-lg bg-emerald-800 px-4 py-3 text-center font-semibold text-white shadow-sm transition hover:bg-emerald-900"
            data-mobile-menu-link
          >
            Termin vereinbaren
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const menu = document.querySelector('[data-mobile-menu]');
    const openBtn = document.querySelector('[data-mobile-menu-button]');
    if (!menu || !openBtn) return;

    const closeBtn = menu.querySelector('[data-mobile-menu-close]');
    const backdrop = menu.querySelector('[data-mobile-menu-backdrop]');
    const links = menu.querySelectorAll('[data-mobile-menu-link]');

    const setOpen = (open) => {
      menu.classList.toggle('hidden', !open);
      openBtn.setAttribute('aria-expanded', String(open));
      if (open) document.body.style.overflow = 'hidden';
      else document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', () => setOpen(true));
    closeBtn?.addEventListener('click', () => setOpen(false));
    backdrop?.addEventListener('click', () => setOpen(false));
    links.forEach((a) => a.addEventListener('click', () => setOpen(false)));

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  })();
</script>
