---
import Container from './Container.astro';
import { getEntry } from 'astro:content';

const siteEntry = await getEntry('site', 'settings');
const site = siteEntry?.data;
---

<footer class="border-t border-slate-200 bg-stone-50">
  <Container class="py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="font-display text-lg text-slate-950">{site?.practiceName ?? 'Praxis Lindenhof Physio'}</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-700">
          {site?.tagline ?? 'Physiotherapie in Zürich mit persönlicher Betreuung.'}
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-950">Navigation</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-700">
          <li><a class="hover:text-slate-950" href="/leistungen">Leistungen</a></li>
          <li><a class="hover:text-slate-950" href="/team">Team</a></li>
          <li><a class="hover:text-slate-950" href="/kontakt">Kontakt</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-950">Kontakt</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-700">
          <li>{site?.phone ?? '+41 44 521 84 30'}</li>
          <li>{site?.email ?? 'kontakt@lindenhof-physio.ch'}</li>
          <li>{site?.postalCodeCity ?? '8008 Zürich'}</li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-950">Qualität</p>
        <p class="mt-3 text-sm leading-relaxed text-slate-700">
          Evidenzbasierte Behandlung, transparente Kommunikation und individuelle Therapieplanung.
        </p>
      </div>
    </div>
    <p class="mt-10 text-xs text-slate-600">
      © {new Date().getFullYear()} {site?.practiceName ?? 'Praxis Lindenhof Physio'}. Alle Rechte vorbehalten.
    </p>
  </Container>
</footer>

